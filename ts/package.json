{
  "name": "pick-and-place",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "dev:table-layout": "vite --config vite.config.table-layout.ts --open /table-layout.html",
    "build:table-layout": "tsc && vite build --config vite.config.table-layout.ts && mv dist-table-layout/table-layout.html dist-table-layout/index.html",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src && stylelint \"src/**/*.css\"",
    "optimize-meshes": "mkdir -p public/so101_assets && for file in ../intermediary-glb/*.glb; do gltf-transform meshopt \"$file\" \"public/so101_assets/$(basename \"$file\")\"; done"
  },
  "dependencies": {
    "meshoptimizer": "^1.1.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.1",
    "@gltf-transform/cli": "^4.4.0",
    "@stylistic/stylelint-plugin": "^4.0.0",
    "@types/node": "^25.2.2",
    "@types/three": "^0.184.1",
    "eslint": "^9.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.12",
    "vitest": "^4.0.18"
  }
}
